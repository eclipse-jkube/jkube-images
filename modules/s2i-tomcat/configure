#!/bin/sh
set -e

CURRENT_DIR=$(dirname $0)

mkdir -p "/deployments"
chmod -R a+rwX "/deployments"

mkdir -p "$CATALINA_HOME/webapps-javaee"
chown -hR 1000 "$CATALINA_HOME"
chgrp -R 0 "$CATALINA_HOME/conf"
chmod -R g+rwX "$CATALINA_HOME/conf"
chgrp -R 0 "$CATALINA_HOME/logs"
chmod -R g+rwX "$CATALINA_HOME/logs"
chgrp -R 0 "$CATALINA_HOME/temp"
chmod -R g+rwX "$CATALINA_HOME/temp"
chgrp -R 0 "$CATALINA_HOME/webapps"
chmod -R g+rwX "$CATALINA_HOME/webapps"
chgrp -R 0 "$CATALINA_HOME/work"
chmod -R g+rwX "$CATALINA_HOME/work"
chgrp -R 0 "$CATALINA_HOME/webapps-javaee"
chmod -R g+rwX "$CATALINA_HOME/webapps-javaee"

cp -rv ${CURRENT_DIR}/s2i /usr/local/s2i
chmod 755 -R /usr/local/s2i/
