#!/bin/sh
set -e

CURRENT_DIR=$(dirname $0)

mkdir -p "/deployments"
chmod -R a+rwX "/deployments"

# Enable Jetty ee10-deploy module for Jakarta EE 10 web application deployment
java -jar "$JETTY_HOME/start.jar" --add-modules=ee10-deploy

mkdir -p "$JETTY_BASE/webapps"
chown -hR 1000 "$JETTY_BASE"
chgrp -R 0 "$JETTY_BASE/webapps"
chmod -R g+rwX "$JETTY_BASE/webapps"

chown -hR 1000 "$TMPDIR"
chgrp -R 0 "$TMPDIR"
chmod -R g+rwX "$TMPDIR"

cp -rv ${CURRENT_DIR}/s2i /usr/local/s2i
chmod 755 -R /usr/local/s2i/
